# ============================================================
# NYC 311 Analytics — Database Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# .env is listed in .gitignore — never commit it.
# ============================================================

# SQL Server hostname or instance name
SQL_SERVER=localhost

# Database name
SQL_DATABASE=NYC311_Analytics

# Authentication mode: "windows" or "sql"
SQL_AUTH=windows

# SQL Authentication only — leave blank if using Windows Auth
SQL_USER=
SQL_PASS=
