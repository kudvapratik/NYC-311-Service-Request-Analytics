table _Measures
	lineageTag: d3c088d1-e022-457d-acb3-1159b27c7d88

	measure 'Total Requests' = Countrows(requests)
		formatString: #,0
		lineageTag: db65033a-be90-4d29-9537-59661e8afe6d

	measure 'Avg Resolution Days' =
			
			AVERAGEX(
			    FILTER(
			        Requests,
			        Requests[resolution_days] <> BLANK()
			    ),
			    Requests[resolution_days]
			)
		formatString: 0.0
		lineageTag: 4b6a1259-bee0-484d-857b-f1b25305ed85

	measure 'SLA Breach Rate %' =
			
			DIVIDE([SLA Breaches], [Total Closed])
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: eb846d88-fab7-4884-848c-da641edf3d0f

	measure 'Total Requests (Display)' =
			
			VAR Num = [Total Requests]
			RETURN
			SWITCH(
			    TRUE(),
			    ABS(Num) >= 1000000, FORMAT(Num/1000000, "0.00") & "M",
			    ABS(Num) >= 1000, FORMAT(Num/1000, "0.00") & "K",
			    FORMAT(Num, "0.00")
			)
		lineageTag: a3e2ef6c-e0f0-4584-97e5-7ac1f67fafd9

	measure 'Avg Resolution Days (Display)' = FORMAT([Avg Resolution Days], "0.00") & " Days"
		lineageTag: 91adc342-e2b7-4003-be4d-26d195585dae

	measure 'Total Closed' =
			
			CALCULATE(
			    COUNTROWS(requests),
			    requests[status] = "Closed"
			)
		formatString: 0
		lineageTag: 6176bc4a-2b5c-4358-bfeb-4d5c88dc68a4

	measure 'Total Open' =
			
			CALCULATE(
			    COUNTROWS(Requests),
			    Requests[status] <> "Closed"
			)
		formatString: 0
		lineageTag: d5ceac48-275d-433d-9ddb-9a780df00a94

	measure 'Closure Rate %' =
			
			DIVIDE([Total Closed], [Total Requests])
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 403cf0a2-174f-4ca3-8d43-cc0b99954094

	measure 'SLA Breaches' =
			
			CALCULATE(
			    COUNTROWS(Requests),
			    Requests[is_sla_breach] = 1
			)
		formatString: 0
		lineageTag: f26f4c36-fdfd-400f-a215-4ccb88424e75

	measure 'SLA Breach Text - Color' =
			
			VAR _rate = [SLA Breach Rate %]
			RETURN
			    SWITCH(
			        TRUE(),
			        ISBLANK(_rate),  "#64748b",
			        _rate >= 0.50,   "#ef4444",  -- Red  ≥20%
			        _rate >= 0.10,   "#f59e0b",  -- Amber 10-20%
			        "#10b981"                    -- Green <10%
			    )
		lineageTag: fbb8a965-4e36-4bc2-8bd2-63913c0a15b4

	measure 'Requests YoY %' =
			
			VAR _curr = [Total Requests]
			VAR _ly   = [Total Requests LY]
			RETURN
			    IF(
			        NOT ISBLANK(_ly),
			        DIVIDE(_curr - _ly, _ly),
			        BLANK()
			    )
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: c88e3a16-734f-43c7-a4f8-3ee959e6bc32

	measure 'Requests MTD' =
			
			CALCULATE(
			    [Total Requests],
			    DATESMTD('Date'[full_date])
			)
		formatString: 0.00
		lineageTag: 08016f7c-1829-40a8-a429-416d07b01b80

	measure 'Requests YTD' =
			
			CALCULATE(
			    [Total Requests],
			    DATESYTD('Date'[full_date])
			)
		formatString: 0.00
		lineageTag: c70b3538-87f3-4d84-aa2e-3f6eaf6de1af

	measure 'Dynamic Title' =
			
			VAR _borough =
			    IF(
			        ISFILTERED(Requests[borough]),
			        SELECTEDVALUE(Requests[borough], "Multiple Boroughs"),
			        "All Boroughs"
			    )
			VAR _year =
			    IF(
			        ISFILTERED('Date'[year]),
			        SELECTEDVALUE('Date'[year], "Multiple Years"),
			        "All Years"
			    )
			RETURN "NYC 311 — " & _borough & " | " & _year
		lineageTag: 61968344-b7bf-4366-a31e-87da4080ce72

	measure 'KPI Color YoY' =
			
			VAR _pct = [Requests YoY %]
			RETURN
			    SWITCH(TRUE(),
			        ISBLANK(_pct),  "#64748b",
			        -- More requests = worse (311 = complaints)
			        _pct >= 0,   "#ef4444",
			        _pct < 0,  "#f59e0b",
			        "#10b981"
			    )
		lineageTag: 3ec87ae0-6ff6-4213-a085-c9adeb2e72cc

	measure 'Total Requests (vs Last Year - Color)' = ```
			
			VAR _curr = [Total Requests]
			VAR _ly   = [Total Requests LY]
			VAR _perc = DIVIDE(_curr - _ly,_ly)
			VAR _format =
			SWITCH(
			    TRUE(), 
			    _perc >0, "Green",
			    _perc <0, "Red",
			    "Grey"
			)
			Return _format
			```
		lineageTag: 1c1b076e-e23c-4633-9ee4-e31abbb39513

	measure 'Closure Rate % (vs Last Year - Color)' = ```
			
			VAR _curr = [Closure Rate %]
			VAR _ly   = [Closure Rate % - LY]
			VAR _perc = DIVIDE(_curr - _ly,_ly)
			VAR _format =
			SWITCH(
			    TRUE(), 
			    _perc >0, "Green",
			    _perc <0, "Red",
			    "Grey"
			)
			Return _format
			```
		lineageTag: c13d4b3a-284b-43f2-975e-a5da0194506a

	measure 'Closure Rate % (vs Last Year)' = ```
			
			VAR _curr = [Closure Rate %]
			VAR _ly   = [Closure Rate % - LY]
			VAR _perc = DIVIDE(_curr - _ly,_ly)
			VAR _format =
			SWITCH(
			    TRUE(), 
			    _perc >0, UNICHAR(11165) & " " & FORMAT(_perc,"0.0%"),
			    _perc <0, UNICHAR(11167) & " " & FORMAT(_perc*-1,"0.0%"),
			    FORMAT(_perc,"0.0%")
			)
			Return _format
			```
		lineageTag: 9b36dbf4-56e8-456b-a4f8-c907943b2f79

	measure 'Closure Rate % - LY' =
			
			CALCULATE(
			    DIVIDE([Total Closed], [Total Requests]),
			    SAMEPERIODLASTYEAR('Date'[full_date])
			)
		lineageTag: 0e52fae4-ea24-4ec5-9329-3bc2db23ca75

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Avg Resolution Days - LY' = ```
			
			CALCULATE(
			    
			AVERAGEX(
			    FILTER(
			        Requests,
			        Requests[resolution_days] <> BLANK()
			    ),
			    Requests[resolution_days]
			),
			    SAMEPERIODLASTYEAR('Date'[full_date])
			)
			```
		lineageTag: f1beb1d6-1193-42e8-ba61-49eb1cf4258a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Avg Resolution Days(vs Last Year)' = ```
			
			VAR _curr = [Avg Resolution Days]
			VAR _ly   = [Avg Resolution Days - LY]
			VAR _perc = _curr - _ly
			VAR _format =
			SWITCH(
			    TRUE(), 
			    _perc >0, UNICHAR(11165) & " " & FORMAT(_perc, "0.00") & " Days",
			    _perc <0, UNICHAR(11167) & " " & FORMAT(_perc*-1, "0.00") & " Days",
			    FORMAT(_perc, "0.00") & " Days"
			)
			Return _format
			```
		lineageTag: 0bbb19fe-da67-41a8-a7cb-984cdab14897

	measure 'Avg Resolution Days(vs Last Year - Color)' = ```
			
			VAR _curr = [Avg Resolution Days]
			VAR _ly   = [Avg Resolution Days - LY]
			VAR _perc = _curr - _ly
			VAR _format =
			SWITCH(
			    TRUE(), 
