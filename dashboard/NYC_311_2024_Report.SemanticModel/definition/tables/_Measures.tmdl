			    Requests[status] <> "Closed",
			    Requests[days_open_if_pending] > 180,
			    Requests[days_open_if_pending] <= 365
			)
		formatString: 0
		lineageTag: ee6e6973-7312-4adb-8083-3deac3e9bd6e

	measure 'Stale Cases Over 365' =
			
