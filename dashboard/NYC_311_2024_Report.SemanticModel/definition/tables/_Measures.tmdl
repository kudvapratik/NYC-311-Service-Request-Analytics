	measure 'Avg Days Color' =
			
			VAR _val = [Avg Resolution Days]
			RETURN
			    SWITCH(TRUE(),
			        ISBLANK(_val),   "#64748b",
			        _val <= 3,       "#059669",   -- deep green
			        _val <= 6,       "#10b981",   -- mid green
			        _val <= 10,      "#6ee7b7",   -- light green
			        _val <= 15,      "#fcd34d",   -- light yellow
			        _val <= 20,      "#f59e0b",   -- amber
			        _val <= 30,      "#f97316",   -- orange
			                         "#ef4444"    -- red
			    )
		lineageTag: aa6cc6ac-1d9a-4c5e-8f88-5edda0427212

	measure 'Vs Citywide Avg' = ```
			
			[Avg Resolution Days] - 
			CALCULATE([Avg Resolution Days], ALL(Requests[borough]))
			```
		lineageTag: 23b70211-c205-42ca-bbc8-3502b14ba633

		annotation PBI_FormatHint = {"isGeneralNumber":true}

