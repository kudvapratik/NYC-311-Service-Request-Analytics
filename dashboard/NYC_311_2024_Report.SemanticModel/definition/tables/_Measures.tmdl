	measure 'Open Aging Bucket Color' =
			
			SWITCH(
			    SELECTEDVALUE(Requests[Open Aging Bucket]),
			    "0–30 days",    "#10b981",
			    "31–90 days",   "#f59e0b",
			    "91–180 days",  "#ef4444",
			    "181–365 days", "#dc2626",
			    "Over 365 days","#7f1d1d",
			    "#64748b"
			)
		lineageTag: 5fdeedb3-ee1d-4772-b7be-2bbae2a2acf7

	measure 'Oldest Case Created Date' =
			
			VAR _maxdays = MAXX(
			    FILTER(Requests, Requests[status] <> "Closed"),
			    Requests[days_open_if_pending]
			)
			RETURN
			CALCULATE(
			    MIN(Requests[created_date]),
			    Requests[days_open_if_pending] = _maxdays
			)
		formatString: General Date
		lineageTag: 9ee1c297-e583-49b7-be1e-85a4a7bbf84e

	measure 'Oldest Case Department' =
			
			VAR _maxdays = MAXX(
			    FILTER(Requests, Requests[status] <> "Closed"),
			    Requests[days_open_if_pending]
			)
			RETURN
			CALCULATE(
			    FIRSTNONBLANK(Requests[agency_name], 1),
			    Requests[days_open_if_pending] = _maxdays
			)
		lineageTag: 2eb33110-cb61-49b1-9135-fc450d6a2a5b

	measure 'Oldest Case Complaint Type' =
			
			VAR _maxdays = MAXX(
			    FILTER(Requests, Requests[status] <> "Closed"),
			    Requests[days_open_if_pending]
			)
			RETURN
			CALCULATE(
			    FIRSTNONBLANK(Requests[complaint_type], 1),
			    Requests[days_open_if_pending] = _maxdays
			)
		lineageTag: c222b2c2-b536-47ba-ade9-a859c1cd44c7

	measure 'Oldest Case Summary' =
			
			VAR _maxdays = MAXX(
			    FILTER(Requests, Requests[status] <> "Closed"),
			    Requests[days_open_if_pending]
			)
			VAR _date = CALCULATE(
			    MIN(Requests[created_date]),
			    Requests[days_open_if_pending] = _maxdays
			)
			VAR _dept = CALCULATE(
			    FIRSTNONBLANK(requests[agency_code], 1),
			    Requests[days_open_if_pending] = _maxdays
			)
			VAR _type = CALCULATE(
			    FIRSTNONBLANK(Requests[complaint_type], 1),
			    Requests[days_open_if_pending] = _maxdays
			)
			RETURN
			_dept  &
			" | " & _type & " | " & FORMAT(_date, "MMM DD, YYYY")
		lineageTag: d677272c-4af8-43eb-80a0-58033909298e

	measure 'Avg Days Waiting vs SLA' =
			
			VAR _avg = [Avg Days Open]
			VAR _sla = AVERAGE(Requests[sla_days])
			RETURN
			_avg - _sla
		lineageTag: 55cc1803-ce58-48ec-9896-5388c1469f82

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Avg Days Waiting vs SLA Label' = ```
			
			VAR _diff = [Avg Days Waiting vs SLA]
			RETURN
			IF(_diff > 0, 
			    "+" & FORMAT(_diff, "0") & " days over SLA target",
			    FORMAT(_diff, "0") & " days under SLA target"
			)
			```
