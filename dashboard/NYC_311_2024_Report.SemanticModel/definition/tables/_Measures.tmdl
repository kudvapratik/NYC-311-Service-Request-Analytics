	measure 'Stale Cases 90 to 180' =
			
			CALCULATE(
			    COUNTROWS(Requests),
			    Requests[status] <> "Closed",
			    Requests[days_open_if_pending] > 90,
			    Requests[days_open_if_pending] <= 180
			)
		formatString: 0
		lineageTag: bd0f3f5d-1e9b-45ea-9d0a-43b920e3d1d4

	measure 'Stale Cases 180 to 365' =
			
			CALCULATE(
