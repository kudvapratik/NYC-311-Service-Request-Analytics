	measure 'Is Last Month Filter' =
			
			IF(
			    MAX('Date'[full_date]) >= EOMONTH(MAXX(ALL('Date'), 'Date'[full_date]), -1) + 1
			    && MAX('Date'[full_date]) <= EOMONTH(MAXX(ALL('Date'), 'Date'[full_date]), 0),
			    1, 0
			)
		formatString: 0
		lineageTag: 9fcdb2d4-52b7-4b3d-85c2-f0a14a932cbd

	measure 'Sparkline Bar Color' =
			
			IF(
			    MAX('Date'[month]) = MONTH(MAXX(ALL('Date'), 'Date'[full_date])),
			    "#0C447C",  -- dark navy for last month
			    "#185FA5"   -- regular navy for all others
