		lineageTag: 6a09bd15-2920-4d44-a808-04de5d4943e7

	measure 'SLA Breach Text' =
			
			VAR _rate = [SLA Breach Rate %]
			RETURN
			    SWITCH(
			        TRUE(),
			        _rate >= 0.20,   "Above 20% threshold",  -- Red  ≥20%
			        _rate >= 0.10,   "Above 10% threshold",  -- Amber 10-20%
			        "Below 10% threshold"                    -- Green <10%
			    )
		lineageTag: ab309ea0-c6d2-4d71-93e9-83a871df131f

	measure 'Total Requests (vs Last Year - Num)' =
			
			VAR _curr = [Total Requests]
			VAR _ly   = [Total Requests LY]
			VAR _perc = DIVIDE(_curr - _ly,_ly)
			Return _perc
		lineageTag: 5e78b80b-57d2-40ef-9f07-9b79420a9b03

	measure 'Total Requests LY' =
			
			CALCULATE(
